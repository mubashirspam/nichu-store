# Razorpay Configuration
# Get your keys from: https://dashboard.razorpay.com/app/keys

# Public key (safe to expose to client)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXX

# Secret key (NEVER expose to client - server-side only)
RAZORPAY_KEY_SECRET=your_secret_key_here

# Webhook secret (REQUIRED for webhook verification)
# Get this from: https://dashboard.razorpay.com/app/webhooks
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000







