# ═══════════════════════════════════════════════════════════════
# Neon Database
# Get from: https://neon.tech → Your Project → Connection String
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# ═══════════════════════════════════════════════════════════════
# Neon Auth (Better Auth)
# Get from: https://neon.tech → Your Project → Auth → Configuration
# ═══════════════════════════════════════════════════════════════
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth
NEON_AUTH_COOKIE_SECRET=generate_with_openssl_rand_base64_32

# ═══════════════════════════════════════════════════════════════
# Vercel Blob Storage
# Get from: Vercel Dashboard → Storage → Blob → Copy Token
# ═════════════════════════════════════════════════════════════
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXXXXX

# ═══════════════════════════════════════════════════════════════
# Razorpay Configuration
# Get from: https://dashboard.razorpay.com/app/keys
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_secret_key_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ═══════════════════════════════════════════════════════════════
# App Configuration
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_APP_URL=http://localhost:3000

